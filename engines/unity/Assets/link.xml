    <assembly fullname="Nobi.UiRoundedCorners">
        <type fullname="ImageWithRoundedCorners" preserve="all"/>
        <type fullname="ImageWithIndependentRoundedCorners" preserve="all"/>
    </assembly>
    <!--
        VendorStoryboardEffectsBootstrap is discovered only via reflection
        (StoryboardVendorEffectsLoader / VendorStoryboardInstall use a string
        literal; there is no static reference). Anchor it so IL2CPP managed
        code stripping cannot remove it at higher stripping levels and silently
        disable the vendor storyboard backend. Tracked here because
        Assets/Vendor/ itself is gitignored.
    -->
    <assembly fullname="Assembly-CSharp">
        <type fullname="Cytoid.Storyboard.Vendor.VendorStoryboardEffectsBootstrap" preserve="all"/>
        <!--
            Cytoid Player constructs its menu and in-game HUD at runtime from
            code (AddComponent<T>). Preserve the controllers and all legacy UGUI
            types they touch so IL2CPP managed-code stripping does not silently
            remove them in standalone Windows builds.
        -->
        <type fullname="CytoidPlayerMenuController" preserve="all"/>
        <type fullname="CytoidPlayerHudController" preserve="all"/>
    </assembly>

    <assembly fullname="UnityEngine.UI">
        <type fullname="UnityEngine.UI.*" preserve="all"/>
        <type fullname="UnityEngine.EventSystems.*" preserve="all"/>
    </assembly>

    <assembly fullname="UnityEngine.CoreModule">
        <type fullname="UnityEngine.Canvas" preserve="all"/>
        <type fullname="UnityEngine.CanvasRenderer" preserve="all"/>
        <type fullname="UnityEngine.RectTransform" preserve="all"/>
        <type fullname="UnityEngine.Font" preserve="all"/>
    </assembly>
</linker>